{
  "nodeModulesDir": "auto",
  "tasks": {
    "dev": "deno run -A --watch main.js",
    "run": "deno run main.js",
    "test": "deno test -A",
    "test:watch": "deno test -A --watch",
    "cvg": "deno test -A --coverage",
    "cvg:detailed": "deno coverage --detailed",
    "automate": "deno run -A automation/room-flow.js",
    "install:browser": "deno run -A npm:playwright install chromium"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/random": "jsr:@std/random@^0.1.5",
    "@std/testing": "jsr:@std/testing@^1.0.17",
    "find-unused-exports": "npm:find-unused-exports@^7.1.1",
    "hono": "npm:hono@^4.12.12",
    "playwright": "npm:playwright@^1.59.1",
    "uuid": "npm:uuid@^13.0.0"
  },
  "fmt": {
    "exclude": [
      "public/**/*.html",
      "public/**/*.css",
      "public/**/*.xml",
      "public/**/*.svg"
    ]
  },
  "compilerOptions": {
    "lib": [
      "deno.ns",
      "dom"
    ]
  },
  "lint": {
    "rules": {
      "include": [
        "no-console"
      ]
    }
  }
}
