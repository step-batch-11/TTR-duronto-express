{
  "tasks": {
    "dev": "deno run -A --watch main.js",
    "run": "deno run main.js",
    "test": "deno test -A",
    "test:watch": "deno test -A --watch",
    "cvg": "deno test -A --coverage"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/random": "jsr:@std/random@^0.1.5",
    "@std/testing": "jsr:@std/testing@^1.0.17",
    "hono": "npm:hono@^4.12.11"
  },
  "fmt": {
    "exclude": [
      "public/**/*.html",
      "public/**/*.css",
      "public/**/*.xml",
      "public/**/*.svg"
    ]
  },
  "compilerOptions": {
    "lib": ["deno.ns", "dom"]
  }
}
